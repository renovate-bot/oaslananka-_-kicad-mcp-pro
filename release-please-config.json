{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "python",
      "package-name": "kicad-mcp-pro",
      "changelog-path": "CHANGELOG.md",
      "draft": true,
      "force-tag-creation": true,
      "pull-request-header": "Release pull request",
      "extra-files": [
        {
          "type": "generic",
          "path": "src/kicad_mcp/__init__.py"
        },
        {
          "type": "json",
          "path": "npm-wrapper/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "mcp.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "mcp.json",
          "jsonpath": "$.packages[0].version"
        },
        {
          "type": "json",
          "path": "server.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "server.json",
          "jsonpath": "$.packages[0].version"
        }
      ]
    }
  },
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "separate-pull-requests": true
}
