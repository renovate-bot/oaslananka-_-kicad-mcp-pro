{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.oaslananka-lab/kicad-mcp-pro",
  "title": "KiCad MCP Pro",
  "description": "A Model Context Protocol server for KiCad EDA workflows.",
  "version": "3.4.2",
  "repository": {
    "url": "https://github.com/oaslananka-lab/kicad-mcp-pro",
    "source": "github"
  },
  "websiteUrl": "https://oaslananka-lab.github.io/kicad-mcp-pro",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "kicad-mcp-pro",
      "version": "3.4.2",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "oci",
      "identifier": "ghcr.io/oaslananka-lab/kicad-mcp-pro:3.4.2",
      "version": "3.4.2",
      "runtimeHint": "docker",
      "transport": {
        "type": "stdio"
      },
      "registry": "container",
      "image": "ghcr.io/oaslananka-lab/kicad-mcp-pro"
    }
  ],
  "capabilities": {
    "tools": true,
    "resources": true,
    "prompts": true
  },
  "license": "MIT"
}
